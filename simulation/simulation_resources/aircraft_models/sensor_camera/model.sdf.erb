<?xml version="1.0" encoding="UTF-8"?>
<%
  dfov_deg = camera_intrinsics['diagonal_fov_deg'].to_f
  clipped_dfov_deg = [dfov_deg, 175.0].min # Cap DFOV to <180 degrees to avoid singularities in the pinhole model
  dfov_rad = clipped_dfov_deg * (Math::PI / 180.0)
  diagonal_pixels = Math.sqrt(camera_intrinsics['width'].to_f**2 + camera_intrinsics['height'].to_f**2)
  focal_length = diagonal_pixels / (2.0 * Math.tan(dfov_rad / 2.0))
  hfov_rad = 2.0 * Math.atan(camera_intrinsics['width'].to_f / (2.0 * focal_length))
%>
<sdf version='1.9'>
  <model name="sensor_camera">
    <link name="mono_cam/base_link">
      <pose>0 0 0 0 0 0</pose>
      <inertial>
        <!-- <mass>0.050</mass> -->
        <mass>0.001</mass>
        <inertia>
          <ixx>0.00004</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.00004</iyy>
          <iyz>0</iyz>
          <izz>0.00004</izz>
        </inertia>
      </inertial>
      <visual name="visual">
        <pose degrees="true">0 0 0 0 -90 0</pose>
        <geometry>
          <cone>
            <radius>0.025</radius>
            <length>0.05</length>
          </cone>
        </geometry>
        <material>
          <ambient>0 1 0 1.0</ambient>
          <diffuse>0 1 0 1.0</diffuse>
        </material>
      </visual>
      <sensor name="imager" type="camera">
      <!-- TODO: https://www.seeedstudio.com/IMX219-200-Camera-200-FOV-Applicable-for-Jetson-Nano-p-4609.html -->
        <camera>
          <horizontal_fov><%= hfov_rad.round(6) %></horizontal_fov>
          <image>
            <width><%= camera_intrinsics['width'] %></width>
            <height><%= camera_intrinsics['height'] %></height>
          </image>
          <clip>
            <near><%= camera_intrinsics['near_clip'] %></near>
            <far><%= camera_intrinsics['far_clip'] %></far>
          </clip>
        </camera>
        <always_on>1</always_on>
        <update_rate><%= camera_intrinsics['update_rate'] %></update_rate>
        <visualize>false</visualize>
        <!-- <topic>camera_1</topic> -->
      </sensor>
      <gravity>true</gravity>
      <velocity_decay/>
    </link>
  </model>
</sdf>