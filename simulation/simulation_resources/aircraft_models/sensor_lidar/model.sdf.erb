<?xml version="1.0" encoding="UTF-8"?>
<%
  # Degrees to radians
  deg_to_rad = Math::PI / 180.0
  h_min_rad = lidar_intrinsics['h_min_angle_deg'].to_f * deg_to_rad
  h_max_rad = lidar_intrinsics['h_max_angle_deg'].to_f * deg_to_rad
  v_min_rad = lidar_intrinsics['v_min_angle_deg'].to_f * deg_to_rad
  v_max_rad = lidar_intrinsics['v_max_angle_deg'].to_f * deg_to_rad
%>
<sdf version='1.9'>
  <model name="sensor_lidar">
    <link name="lidar/base_link">
      <pose>0 0 0 0 0 0</pose>
      <inertial>
        <!-- <mass>0.37</mass> -->
        <mass>0.001</mass>
        <inertia>
          <ixx>0.00034437749999999994</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.00034437749999999994</iyy>
          <iyz>0</iyz>
          <izz>0.00022199999999999998</izz>
        </inertia>
      </inertial>
      <visual name="visual">
        <pose degrees="true">0 0 0 0 0 0</pose>
        <geometry>
          <cone>
            <radius>0.03</radius>
            <length>0.03</length>
          </cone>
        </geometry>
        <material>
          <ambient>0 0 1 1.0</ambient>
          <diffuse>0 0 1 1.0</diffuse>
        </material>
      </visual>
      <sensor name="lidar3d" type="gpu_lidar">
      <!-- https://www.livoxtech.com/mid-360/specs -->
        <lidar>
          <scan>
            <horizontal>
              <samples><%= lidar_intrinsics['horizontal_samples'] %></samples>
              <resolution>1</resolution>
              <min_angle><%= h_min_rad.round(6) %></min_angle>
              <max_angle><%= h_max_rad.round(6) %></max_angle>
            </horizontal>
            <vertical>
              <samples><%= lidar_intrinsics['vertical_samples'] %></samples>
              <resolution>1</resolution>
              <min_angle><%= v_min_rad.round(6) %></min_angle>
              <max_angle><%= v_max_rad.round(6) %></max_angle>
            </vertical>
          </scan>
          <range>
            <min><%= lidar_intrinsics['min_range'] %></min>
            <max><%= lidar_intrinsics['max_range'] %></max>
            <resolution><%= lidar_intrinsics['range_resolution'] %></resolution>
          </range>
          <noise>
            <type>gaussian</type>
            <mean>0.0</mean>
            <stddev>0.001</stddev>
          </noise>
        </lidar>
        <always_on>1</always_on>
        <update_rate><%= lidar_intrinsics['update_rate'] %></update_rate>
        <visualize>true</visualize>
        <!-- <topic>lidar3d</topic> -->
      </sensor>
    </link>
  </model>
</sdf>